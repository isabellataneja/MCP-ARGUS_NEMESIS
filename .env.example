# Supabase (service role key is server-only; never expose to clients or tool output)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for Authorization: Bearer on POST /mcp
MCP_BEARER_TOKEN=

# HTTP port (Railway sets PORT automatically)
PORT=8080

# Region that tools default to when caller does not pass `region`.
# Must be one of: AX-BD-Dhaka, AX-IN-Bangalore, IN-IDS-Mohali, IN-IDS-Noida, SL-Medsource-Colombo, AX-US-San Francisco
MCP_DEFAULT_REGION=AX-BD-Dhaka

# Set to 'true' AFTER running the SQL migration that adds a `region` column to bd_holidays.
MCP_HOLIDAYS_HAVE_REGION=false
